# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# Home-directory protection
# This repo's root is currently the Windows home folder (C:\Users\dakot), so the
# entire home directory sits inside the git working tree. These rules make sure
# system/credential files can NEVER be accidentally staged (e.g. via git add -A).
# The real fix is to move the app into its own repo — see notes — but keep these.
# -----------------------------------------------------------------------------
NTUSER.DAT*
ntuser.dat*
ntuser.ini
*.regtrans-ms
*.TM.blf
*Credentials*
/AppData/
/Application Data/
/Local Settings/
/Cookies/
/Contacts/
/Downloads/
/Favorites/
/Links/
/Music/
/Videos/
/Searches/
/Saved Games/
/OneDrive/
/IntelGraphicsProfiles/
/Documents/
/Pictures/
/Desktop/
.claude/
.claude.json*
.cursor/
.gitconfig
.node_repl_history
.config/
